{
  "title": "Invoice OCR v3",
  "uid": "invoice-ocr-v3",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"id": 1, "title": "Inflight jobs", "type": "stat",
     "targets": [{"expr": "sum(ocr_inflight_jobs)"}],
     "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}},
    {"id": 2, "title": "Queue depth", "type": "stat",
     "targets": [{"expr": "ocr_queue_depth"}],
     "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}},
    {"id": 3, "title": "Requests by status", "type": "timeseries",
     "targets": [{"expr": "sum by (status) (rate(ocr_api_requests_total[1m]))"}],
     "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}},
    {"id": 4, "title": "End-to-end latency p95", "type": "timeseries",
     "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(ocr_e2e_latency_seconds_bucket[5m])))"}],
     "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}},
    {"id": 5, "title": "Stage latency p95", "type": "timeseries",
     "targets": [{"expr": "histogram_quantile(0.95, sum by (le, stage) (rate(ocr_stage_duration_seconds_bucket[5m])))", "legendFormat": "{{stage}}"}],
     "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}},
    {"id": 6, "title": "Triton batch size p50/p95", "type": "timeseries",
     "targets": [
       {"expr": "histogram_quantile(0.50, sum by (le) (rate(ocr_triton_batch_size_bucket[1m])))", "legendFormat": "p50"},
       {"expr": "histogram_quantile(0.95, sum by (le) (rate(ocr_triton_batch_size_bucket[1m])))", "legendFormat": "p95"}
     ],
     "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}},
    {"id": 7, "title": "pHash hit ratio", "type": "stat",
     "targets": [{"expr": "rate(ocr_phash_hits_total[5m]) / (rate(ocr_phash_hits_total[5m]) + rate(ocr_phash_misses_total[5m]))"}],
     "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16}},
    {"id": 8, "title": "Gemini retries", "type": "timeseries",
     "targets": [{"expr": "sum by (attempt) (rate(ocr_gemini_retries_total[5m]))"}],
     "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}},
    {"id": 9, "title": "Backpressure rejections", "type": "timeseries",
     "targets": [{"expr": "rate(ocr_backpressure_rejections_total[5m])"}],
     "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}},
    {"id": 10, "title": "Stale jobs recovered", "type": "timeseries",
     "targets": [{"expr": "rate(ocr_stale_jobs_recovered_total[5m])"}],
     "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}},
    {"id": 11, "title": "Whitelist match tier", "type": "timeseries",
     "targets": [{"expr": "sum by (field, tier) (rate(ocr_whitelist_match_total[5m]))", "legendFormat": "{{field}}/{{tier}}"}],
     "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}},
    {"id": 12, "title": "Token bucket available", "type": "timeseries",
     "targets": [{"expr": "ocr_token_bucket_available"}],
     "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40}},
    {"id": 13, "title": "Storage errors", "type": "timeseries",
     "targets": [{"expr": "sum by (service) (rate(ocr_storage_errors_total[5m]))"}],
     "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40}},
    {"id": 14, "title": "Orphan jobs", "type": "timeseries",
     "targets": [{"expr": "rate(ocr_orphan_jobs_total[5m])"}],
     "gridPos": {"h": 8, "w": 24, "x": 0, "y": 48}}
  ]
}
