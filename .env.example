# Invoice OCR v4 — CDN-based experimental system. Copy to .env and fill values.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
PROMPT_SEMANTIC_VERSION=v3.7

REDIS_URL=redis://redis:6379
POSTGRES_DSN=postgresql+asyncpg://invoice:invoice@postgres:5432/invoice_ocr
TRITON_HOST=triton:8001

# CDN Download (worker fetches images from external CDN)
IMAGE_DOWNLOAD_TIMEOUT_SECONDS=30
IMAGE_DOWNLOAD_MAX_BYTES=10485760
ALLOWED_IMAGE_DOMAINS=img-campaign.gotit.vn

API_METRICS_PORT=9101
WORKER_METRICS_PORT=9102
WORKER_CONCURRENCY=4

LOG_LEVEL=INFO
